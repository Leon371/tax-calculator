/* pages/city-select/city-select.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.search-box {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.search-input {
  font-size: 28rpx;
  color: #333;
}

.current-city {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.current-city .label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.city-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  color: #0AAD8C;
  font-weight: 500;
}

.check {
  color: #0AAD8C;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.city-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.city-tag {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.city-tag.active {
  background: #0AAD8C;
  color: #fff;
}
