/* pages/result/result.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.main-result {
  text-align: center;
  background: linear-gradient(135deg, #0AAD8C 0%, #07c4a4 100%);
}

.result-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.result-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #fff;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.highlight {
  color: #333;
  font-weight: 600;
}

.highlight-value {
  color: #0AAD8C;
  font-weight: 700;
}

.final-result {
  text-align: center;
  background: linear-gradient(135deg, #0AAD8C 0%, #07c4a4 100%);
}

.final-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin: 10rpx 0;
}

.final-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.btn-group {
  display: flex;
  gap: 20rpx;
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.btn-primary {
  background: #0AAD8C;
  color: #fff;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
  cursor: pointer;
}

.btn-secondary:active {
  background: #e0e0e0;
}

.btn-current {
  background: #e0e0e0;
  color: #999;
  border: none;
}

/* 抽屉样式 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 100;
}

.drawer-mask.show {
  opacity: 1;
  visibility: visible;
}

.drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f5f7fa;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 101;
  max-height: 85vh;
  overflow-y: auto;
  padding-bottom: 40rpx;
}

.drawer.show {
  transform: translateY(0);
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-bottom: 1rpx solid #eee;
}

.drawer-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.month-selector {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
}

.month-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  color: #0AAD8C;
  background: #f0f9f7;
  border-radius: 50%;
}

.month-display {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin: 0 40rpx;
}
