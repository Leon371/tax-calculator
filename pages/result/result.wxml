<!--pages/result/result.wxml-->
<view class="container">
  <view class="header">
    <view class="header-title">计算结果</view>
    <view class="header-subtitle">{{result.city}}</view>
  </view>

  <view class="card final-result">
    <view class="final-value">¥{{result.afterTaxIncome}}</view>
    <view class="final-label">税后收入（年度）</view>
  </view>

  <view class="card">
    <view class="card-title">收入明细（年度）</view>
    <view class="detail-row">
      <text>月薪收入</text>
      <text>¥{{result.yearlySalary}}</text>
    </view>
    <view class="detail-row">
      <text>年终奖</text>
      <text>¥{{result.bonus}}</text>
    </view>
    <view class="detail-row highlight">
      <text>年度总收入</text>
      <text>¥{{result.annualIncome}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">扣除明细（年度）</view>
    <view class="detail-row">
      <text>基本减除费用</text>
      <text>¥60000</text>
    </view>
    <view class="detail-row">
      <text>社保公积金</text>
      <text>¥{{result.yearlySocial}}</text>
    </view>
    <view class="detail-row">
      <text>专项附加扣除</text>
      <text>¥{{result.yearlyExtra}}</text>
    </view>
    <view class="detail-row highlight">
      <text>应纳税所得额</text>
      <text>¥{{result.yearlyTaxable}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">税额明细</view>
    <view class="detail-row">
      <text>月薪税额（每月）</text>
      <text>¥{{result.monthlyTax}}</text>
    </view>
    <view class="detail-row">
      <text>年终奖税额</text>
      <text>¥{{result.bonusTax}}</text>
    </view>
    <view class="detail-row highlight">
      <text>年度税额合计</text>
      <text class="highlight-value">¥{{result.totalTax}}</text>
    </view>
  </view>

  <view class="btn-group">
    <view class="btn btn-current">年度结果</view>
    <view class="btn btn-primary" bindtap="goBack">税后收入（年度）</view>
  </view>

  <!-- 抽屉 -->
  <view class="drawer-mask {{showMonthlyDrawer ? 'show' : ''}}" bindtap="closeMonthlyDrawer"></view>
  <view class="drawer {{showMonthlyDrawer ? 'show' : ''}}">
    <view class="drawer-header">
      <text>月度收入</text>
      <text class="drawer-close" bindtap="closeMonthlyDrawer">×</text>
    </view>
    
    <view class="month-selector">
      <view class="month-btn" bindtap="prevMonth">&lt;</view>
      <view class="month-display">{{monthlyData.year}}年{{monthlyData.month}}月</view>
      <view class="month-btn" bindtap="nextMonth">&gt;</view>
    </view>

    <view class="card final-result">
      <view class="final-value">¥{{monthlyData.monthlyIncome}}</view>
      <view class="final-label">本月税后收入</view>
    </view>

    <view class="card">
      <view class="card-title">累计数据（1-{{monthlyData.month}}月）</view>
      <view class="detail-row">
        <text>累计收入</text>
        <text>¥{{monthlyData.cumulativeData.totalIncome}}</text>
      </view>
      <view class="detail-row">
        <text>累计减除费用</text>
        <text>¥{{monthlyData.cumulativeData.totalDeduction}}</text>
      </view>
      <view class="detail-row">
        <text>累计社保公积金</text>
        <text>¥{{monthlyData.cumulativeData.totalSocial}}</text>
      </view>
      <view class="detail-row">
        <text>累计专项附加扣除</text>
        <text>¥{{monthlyData.cumulativeData.totalExtra}}</text>
      </view>
      <view class="detail-row highlight">
        <text>累计应税所得</text>
        <text>¥{{monthlyData.cumulativeData.taxableIncome}}</text>
      </view>
    </view>

    <view class="card">
      <view class="card-title">税额计算</view>
      <view class="detail-row">
        <text>累计应纳税额</text>
        <text>¥{{monthlyData.cumulativeData.cumulativeTax}}</text>
      </view>
      <view class="detail-row">
        <text>已缴税额</text>
        <text>¥{{monthlyData.cumulativeData.paidTax}}</text>
      </view>
      <view class="detail-row highlight">
        <text>本月应缴税额</text>
        <text class="highlight-value">¥{{monthlyData.monthlyTax}}</text>
      </view>
    </view>
  </view>
</view>
