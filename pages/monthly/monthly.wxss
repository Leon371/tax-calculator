/* pages/monthly/monthly.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.month-selector {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.month-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  color: #0AAD8C;
  background: #f0f9f7;
  border-radius: 50%;
}

.month-display {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin: 0 40rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.summary {
  text-align: center;
  background: linear-gradient(135deg, #0AAD8C 0%, #07c4a4 100%);
}

.summary-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.summary-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #fff;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.highlight {
  color: #333;
  font-weight: 600;
}

.highlight-value {
  color: #0AAD8C;
  font-weight: 700;
  font-size: 32rpx;
}

.final-result {
  text-align: center;
  background: linear-gradient(135deg, #0AAD8C 0%, #07c4a4 100%);
}

.final-result .final-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin: 10rpx 0;
}

.final-result .final-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 20rpx;
}
