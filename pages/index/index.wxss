/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.city-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.city-label {
  font-size: 28rpx;
  color: #666;
}

.city-value {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  color: #0AAD8C;
  font-weight: 500;
}

.arrow {
  margin-left: 10rpx;
  color: #999;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.input-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.input-group:last-child {
  border-bottom: none;
}

.input-label {
  font-size: 28rpx;
  color: #666;
}

.input-label-wrap {
  display: flex;
  flex-direction: column;
}

.input-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333;
  margin-left: 20rpx;
}

.deduction-list {
  display: flex;
  flex-direction: column;
}

.deduction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.deduction-item:last-child {
  border-bottom: none;
}

.deduction-item text {
  font-size: 28rpx;
  color: #666;
}

.input-small {
  width: 180rpx;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
}

.auto-calc {
  margin-top: 20rpx;
  text-align: center;
  padding: 20rpx;
  color: #0AAD8C;
  font-size: 28rpx;
  background: #f0f9f7;
  border-radius: 8rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.btn-primary {
  background: #0AAD8C;
  color: #fff;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
}
