/* pages/tax-table/tax-table.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.table {
  font-size: 24rpx;
}

.table-header {
  display: flex;
  background: #0AAD8C;
  color: #fff;
  padding: 20rpx 0;
  border-radius: 8rpx;
  font-weight: 600;
}

.table-header text {
  flex: 1;
  text-align: center;
}

.table-row {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  color: #666;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row text {
  flex: 1;
  text-align: center;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.explain {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.explain-item {
  margin-bottom: 10rpx;
}
